{
  "name": "kor-travel-map-admin-frontend",
  "version": "0.2.0-dev",
  "description": "Debug UI frontend for kor-travel-map (Next.js + MapLibre GL + VWorld style builder).",
  "private": true,
  "scripts": {
    "dev": "next dev --port 12705 --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --port 12705 --hostname 127.0.0.1",
    "lint": "eslint .",
    "type-check": "tsc --noEmit && tsc -p e2e/tsconfig.json --noEmit",
    "type-check:e2e": "tsc -p e2e/tsconfig.json --noEmit",
    "doctor": "react-doctor --full --no-score --no-telemetry .",
    "gen:types": "openapi-typescript ../../kor-travel-map-api/openapi.json -o src/api/types.ts",
    "gen:types:check": "openapi-typescript ../../kor-travel-map-api/openapi.json -o src/api/types.ts --check",
    "test": "vitest run --exclude \"e2e/**\" --passWithNoTests",
    "e2e": "playwright test",
    "e2e:mocked": "playwright test",
    "e2e:live": "playwright test --config playwright.live.config.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@kor-travel-map/map-marker-react": "*",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^5.24.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "react-doctor": "^0.2.16",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.9"
  }
}
