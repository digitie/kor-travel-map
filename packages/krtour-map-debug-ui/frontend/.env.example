# =============================================================================
# krtour-map-debug-ui frontend .env (ADR-025, Next.js 기반)
#   - .env.local로 복사해서 사용. .env.local은 .gitignore (절대 commit X).
#   - VWorld API key는 HTTP referrer 제한 설정 권장 (운영자).
#   - Next.js env 규약: NEXT_PUBLIC_* 만 브라우저 노출, 그 외는 server-only.
# =============================================================================

# ----- VWorld 지도 (maplibre-vworld, ADR-025 + ADR-026) -----
# python-kraddr-geo ADR-019의 KRADDR_GEO_VWORLD_API_KEY를 **공유 사용**.
# 별도 발급 금지 (ADR-025 사용자 보강 2026-05-25).
# 운영 시 backend가 .env(KRADDR_GEO_VWORLD_API_KEY)에서 읽어 frontend 빌드 시
# 동일 값을 NEXT_PUBLIC_VWORLD_API_KEY로 주입 (CI/CD 또는 운영 셸 스크립트 책임).
# HTTP referrer 제한 권장 (backend 호스트 + TripMate frontend 호스트).
NEXT_PUBLIC_VWORLD_API_KEY=CHANGE_ME  # = $KRADDR_GEO_VWORLD_API_KEY 값과 동일해야 함

# ----- Backend API base URL -----
# 개발: Next.js dev (8610) → FastAPI (8600). 운영: Next.js standalone 또는
# next/api proxy로 FastAPI와 같은 호스트에 배치.
NEXT_PUBLIC_KRTOUR_MAP_DEBUG_UI_API=http://127.0.0.1:8600

# ----- 옵션 -----
# NEXT_PUBLIC_MAP_DEFAULT_LON=127.0
# NEXT_PUBLIC_MAP_DEFAULT_LAT=37.5
# NEXT_PUBLIC_MAP_DEFAULT_ZOOM=10
