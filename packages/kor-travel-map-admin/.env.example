# =============================================================================
# kor-travel-map-admin backend .env.example  (PR#47, 2026-05-28)
#
# AdminSettings는 `KOR_TRAVEL_MAP_ADMIN_*` prefix를 사용한다. 각 provider repo
# (`python-kma-api`, `python-opinet-api`, ...)의 `.env`에 박힌 키를 그대로
# 복사해서 prefix만 붙여 본 .env에 옮긴다.
#
# 예 (`python-kma-api/.env`):
#     KMA_SERVICE_KEY=abcd1234...
# → 본 lib 측 (`packages/kor-travel-map-admin/.env`):
#     KOR_TRAVEL_MAP_ADMIN_KMA_SERVICE_KEY=abcd1234...
#
# ADR-005 + ADR-035: 키는 코드 외부 — 운영 환경에서는 시스템 secret store
# (Cloudflare Tunnel/SSO 게이트웨이/Vault) 사용 권장. .env 파일은 권한 600.
# =============================================================================

# -- 서버 바인드 --------------------------------------------------------------
# uvicorn host/port. 0.0.0.0 직접 바인드 금지 — Cloudflare Tunnel/SSO 뒤.
KOR_TRAVEL_MAP_ADMIN_HOST=127.0.0.1
KOR_TRAVEL_MAP_ADMIN_PORT=12301
KOR_TRAVEL_MAP_ADMIN_WEB_PORT=12305
KOR_TRAVEL_MAP_DAGSTER_PORT=12302
KOR_TRAVEL_MAP_ADMIN_DAGSTER_URL=http://127.0.0.1:12302
KOR_TRAVEL_MAP_ADMIN_DAGSTER_ALLOWED_HOSTS=["127.0.0.1","localhost","::1","dagster"]
KOR_TRAVEL_MAP_ADMIN_DAGSTER_REPOSITORY_NAME=__repository__
KOR_TRAVEL_MAP_ADMIN_DAGSTER_REPOSITORY_LOCATION_NAME=kortravelmap.dagster.definitions
KOR_TRAVEL_MAP_ADMIN_BACKUP_ROOT=data/backups
KOR_TRAVEL_MAP_ADMIN_BACKUP_PROJECT_ROOT=.
KOR_TRAVEL_MAP_ADMIN_BACKUP_SCRIPT_PATH=scripts/docker-backup.sh
KOR_TRAVEL_MAP_ADMIN_RESTORE_SCRIPT_PATH=scripts/docker-restore.sh
KOR_TRAVEL_MAP_ADMIN_BACKUP_COMMAND_ENABLED=false
KOR_TRAVEL_MAP_ADMIN_BACKUP_COMMAND_TIMEOUT_SECONDS=1800
KOR_TRAVEL_MAP_ADMIN_RESTORE_APP_DB=kor_travel_map_restore
KOR_TRAVEL_MAP_ADMIN_RESTORE_DAGSTER_DB=kor_travel_map_dagster_restore
KOR_TRAVEL_MAP_ADMIN_RESTORE_RUSTFS_VOLUME=kor-travel-map-rustfs-restore
KOR_TRAVEL_MAP_DOCKER_ADMIN_DAGSTER_URL=http://dagster:12302
KOR_TRAVEL_MAP_DOCKER_ADMIN_DAGSTER_ALLOWED_HOSTS=["dagster","127.0.0.1","localhost","::1"]
NEXT_PUBLIC_KOR_TRAVEL_MAP_DAGSTER_URL=http://127.0.0.1:12302
DAGSTER_DISABLE_TELEMETRY=yes
KOR_TRAVEL_MAP_ADMIN_LOG_LEVEL=info

# Prometheus pull scrape endpoint. kor-travel-docker-manager 관측 스택은
# Prometheus 12601 / cAdvisor 12602 / Grafana 12605를 사용하고, API 포트
# 12301의 이 path를 scrape한다. REST HTTP와 DB query 성능 메트릭을 함께 제공한다.
KOR_TRAVEL_MAP_ADMIN_PROMETHEUS_METRICS_ENABLED=true
KOR_TRAVEL_MAP_ADMIN_PROMETHEUS_METRICS_PATH=/metrics

# -- 메인 라이브러리 공유 설정 ----------------------------------------------
# offline upload validation / feature update scope 보강에서 쓰는 kor-travel-geo REST.
KOR_TRAVEL_MAP_KOR_TRAVEL_GEO_BASE_URL=http://127.0.0.1:12201
KOR_TRAVEL_MAP_KOR_TRAVEL_GEO_TIMEOUT_SECONDS=10.0

# -- 라우터 활성화 ------------------------------------------------------------
# /debug/* 라우터 — 프로덕션 admin-only 시 false로.
KOR_TRAVEL_MAP_ADMIN_DEBUG_ROUTES_ENABLED=true

# -- Provider API keys (ETL preview source=live용) ----------------------------
# 각 provider repo의 .env에서 동일 이름 키를 복사. 미설정 시 ?source=live는
# 503 (key not configured)으로 응답.
# 루트 `.env`에 기존 provider 키 이름만 있을 때는 `scripts/load-env.sh`와
# `docker-compose.yml`이 아래 `KOR_TRAVEL_MAP_ADMIN_*` 이름으로 export한다.

# 기상청 동네예보(단기/초단기) + 특보 fallback — apis.data.go.kr 게이트웨이.
# source: python-kma-api/.env 의 DATA_GO_KR_SERVICE_KEY (게이트웨이 공통키).
KOR_TRAVEL_MAP_ADMIN_KMA_SERVICE_KEY=

# 기상청 API 허브 authKey (apihub.kma.go.kr) — 위 serviceKey와 **다른 키**.
# KMA 소스 정책: data.go.kr이 primary, apihub는 fallback. 특보현황은 위
# KMA_SERVICE_KEY(getWthrWrnList)가 primary, 이 apihub wrn_now_data(구조화
# 특보구역)는 data.go.kr 실패 시 fallback. source: python-kma-api/.env 의
# KMA_APIHUB_AUTH_KEY. ⚠️ apihub는 API별 '활용신청' 필요(미신청 시 403).
KOR_TRAVEL_MAP_ADMIN_KMA_APIHUB_KEY=

# OpiNet 한국석유공사 (opinet.co.kr certkey).
# source: python-opinet-api/.env 의 OPINET_API_KEY.
KOR_TRAVEL_MAP_ADMIN_OPINET_SERVICE_KEY=

# data.go.kr 표준데이터 (전국문화축제) — 게이트웨이 공통키.
# source: python-datagokr-api/.env 의 DATA_GO_KR_SERVICE_KEY (KMA와 동일 값 가능).
KOR_TRAVEL_MAP_ADMIN_DATAGOKR_SERVICE_KEY=

# VisitKorea TourAPI (datagokr 1차의 enrichment).
# source: python-visitkorea-api/.env 의 KTO_DATA_GO_KR_SERVICE_KEY.
KOR_TRAVEL_MAP_ADMIN_VISITKOREA_SERVICE_KEY=

# 한국도로공사 휴게소 (data.ex.co.kr key — data.go.kr serviceKey와 다름).
# source: python-krex-api/.env 의 KEX_GO_API_KEY.
KOR_TRAVEL_MAP_ADMIN_KREX_SERVICE_KEY=

# 국립공원공단 (python-knps-api — 보통 keyless file 기반, 일부 endpoint만 키)
KOR_TRAVEL_MAP_ADMIN_KNPS_SERVICE_KEY=

# 대기질 (python-airkorea-api)
KOR_TRAVEL_MAP_ADMIN_AIRKOREA_SERVICE_KEY=

# 산림청 (python-krforest-api) — 산악기상 / trails / 휴양림
KOR_TRAVEL_MAP_ADMIN_KRFOREST_SERVICE_KEY=
