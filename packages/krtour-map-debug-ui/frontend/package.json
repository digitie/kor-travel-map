    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@krtour/map-marker-react": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
