# =============================================================================
# krtour-map-debug-ui backend .env.example  (PR#47, 2026-05-28)
#
# DebugUiSettings는 `KRTOUR_MAP_DEBUG_UI_*` prefix를 사용한다. 각 provider repo
# (`python-kma-api`, `python-opinet-api`, ...)의 `.env`에 박힌 키를 그대로
# 복사해서 prefix만 붙여 본 .env에 옮긴다.
#
# 예 (`python-kma-api/.env`):
#     KMA_SERVICE_KEY=abcd1234...
# → 본 lib 측 (`packages/krtour-map-debug-ui/.env`):
#     KRTOUR_MAP_DEBUG_UI_KMA_SERVICE_KEY=abcd1234...
#
# ADR-005 + ADR-035: 키는 코드 외부 — 운영 환경에서는 시스템 secret store
# (Cloudflare Tunnel/SSO 게이트웨이/Vault) 사용 권장. .env 파일은 권한 600.
# =============================================================================

# -- 서버 바인드 --------------------------------------------------------------
# uvicorn host/port. 0.0.0.0 직접 바인드 금지 — Cloudflare Tunnel/SSO 뒤.
KRTOUR_MAP_DEBUG_UI_HOST=127.0.0.1
KRTOUR_MAP_DEBUG_UI_PORT=8087
KRTOUR_MAP_DEBUG_UI_LOG_LEVEL=info

# -- 라우터 활성화 ------------------------------------------------------------
# /debug/* 라우터 — 프로덕션 admin-only 시 false로.
KRTOUR_MAP_DEBUG_UI_DEBUG_ROUTES_ENABLED=true

# -- Provider API keys (ETL preview source=live용) ----------------------------
# 각 provider repo의 .env에서 동일 이름 키를 복사. 미설정 시 ?source=live는
# 503 (key not configured)으로 응답.

# 기상청 공공데이터포털 (python-kma-api) — 동네예보(단기/초단기)
KRTOUR_MAP_DEBUG_UI_KMA_SERVICE_KEY=

# 기상청 API 허브 authKey (apihub.kma.go.kr) — 위 serviceKey와 다른 키.
# 특보현황(kma_weather_alerts) live는 apihub wrn_now_data가 구조화 특보구역을
# 줘서 이 키 사용 (PR#58). python-kma-api/.env 의 KMA_APIHUB_AUTH_KEY 값.
KRTOUR_MAP_DEBUG_UI_KMA_APIHUB_KEY=

# OpiNet 한국석유공사 (python-opinet-api)
KRTOUR_MAP_DEBUG_UI_OPINET_SERVICE_KEY=

# data.go.kr 표준데이터 (python-datagokr-api) — 본 lib datagokr 1차 source
KRTOUR_MAP_DEBUG_UI_DATAGOKR_SERVICE_KEY=

# VisitKorea TourAPI (python-visitkorea-api) — datagokr 1차의 enrichment
KRTOUR_MAP_DEBUG_UI_VISITKOREA_SERVICE_KEY=

# 도로공사 휴게소 (python-krex-api)
KRTOUR_MAP_DEBUG_UI_KREX_SERVICE_KEY=

# 국립공원공단 (python-knps-api — 보통 keyless file 기반, 일부 endpoint만 키)
KRTOUR_MAP_DEBUG_UI_KNPS_SERVICE_KEY=

# 대기질 (python-airkorea-api)
KRTOUR_MAP_DEBUG_UI_AIRKOREA_SERVICE_KEY=

# 산림청 (python-krforest-api) — 산악기상 / trails / 휴양림
KRTOUR_MAP_DEBUG_UI_KRFOREST_SERVICE_KEY=
