# =============================================================================
# kor-travel-map .env (мҳҲмӢң)
#   - мӢӨм ң .env нҢҢмқјмқҖ к¶Ңн•ң 600 лҳҗлҠ” systemd EnvironmentFile/vaultм—җ л‘”лӢӨ.
#   - нҸүл¬ё м»Өл°Ӣ кёҲм§Җ. SecretStrлЎң settingsм—җ лЎңл“ңн•ңлӢӨ.
# =============================================================================

# ----- Postgres / PostGIS -----
KOR_TRAVEL_MAP_POSTGRES_HOST_PORT=5432
KOR_TRAVEL_MAP_POSTGRES_DB=kor_travel_map
KOR_TRAVEL_MAP_POSTGRES_USER=kor_travel_map
KOR_TRAVEL_MAP_POSTGRES_PASSWORD=CHANGE_ME
KOR_TRAVEL_MAP_PG_DSN=postgresql+asyncpg://kor_travel_map:CHANGE_ME@127.0.0.1:5432/kor_travel_map
# asyncpgмҷҖ л¶„лҰ¬лҗң sync driverк°Җ н•„мҡ”н•ң лҸ„кө¬(Alembic л“ұ)лҠ” лӢӨмқҢмқ„ м¶”к°ҖлЎң м •мқҳ к°ҖлҠҘ
# KOR_TRAVEL_MAP_PG_DSN_SYNC=postgresql+psycopg://kor_travel_map:CHANGE_ME@127.0.0.1:5432/kor_travel_map
KOR_TRAVEL_MAP_DAGSTER_POSTGRES_DB=kor_travel_map_dagster
KOR_TRAVEL_MAP_DAGSTER_PG_URL=postgresql://kor_travel_map:CHANGE_ME@127.0.0.1:5432/kor_travel_map_dagster
KOR_TRAVEL_MAP_DOCKER_DAGSTER_PG_URL=postgresql://kor_travel_map:kor_travel_map@postgres:5432/kor_travel_map_dagster
# kor-travel-docker-manager кіөмң  PostGIS(:5432)лҘј м“ё л•ҢлҠ” local postgresлҘј лқ„мҡ°м§Җ м•ҠлҠ”лӢӨ.
#   KOR_TRAVEL_MAP_INFRA_EXTERNAL=true
#   KOR_TRAVEL_MAP_EXTERNAL_DOCKER_PG_DSN=postgresql+asyncpg://kor_travel_map:CHANGE_ME@host.docker.internal:5432/kor_travel_map
#   KOR_TRAVEL_MAP_EXTERNAL_DOCKER_DAGSTER_PG_URL=postgresql://kor_travel_map:CHANGE_ME@host.docker.internal:5432/kor_travel_map_dagster
KOR_TRAVEL_MAP_PG_POOL_SIZE=10
KOR_TRAVEL_MAP_PG_MAX_OVERFLOW=10
KOR_TRAVEL_MAP_PG_POOL_PRE_PING=true

# ----- л””лІ„к·ё REST API/UI (лі„лҸ„ нҢЁнӮӨм§Җ kor-travel-map-admin, ADR-020) -----
# л””лІ„к·ё нҢЁнӮӨм§ҖлҠ” л©”мқё лқјмқҙлёҢлҹ¬лҰ¬мҷҖ лҸҷмқј .env лҳҗлҠ” лі„лҸ„ .envм—җм„ң лЎңл“ң к°ҖлҠҘ.
# лі„лҸ„ нҢЁнӮӨм§Җм—җм„ң мқёмӢқн•ҳлҠ” prefixлҠ” KOR_TRAVEL_MAP_ADMIN_*.
# Docker compose host publish кё°ліёк°’мқҖ localhostлӢӨ. мҷёл¶Җ л…ём¶ңмқҖ л„ӨнҠёмӣҢнҒ¬ ліҙнҳёлҘј
# лЁјм Җ л‘” л’Ө лӘ…мӢң opt-inн•ңлӢӨ.
# KOR_TRAVEL_MAP_DOCKER_BIND_HOST=0.0.0.0
KOR_TRAVEL_MAP_ADMIN_HOST=127.0.0.1       # мҷёл¶Җ л…ём¶ң кёҲм§Җ default
KOR_TRAVEL_MAP_ADMIN_PORT=12301
KOR_TRAVEL_MAP_ADMIN_WEB_PORT=12305
KOR_TRAVEL_MAP_DAGSTER_PORT=12302
KOR_TRAVEL_MAP_ADMIN_DAGSTER_URL=http://127.0.0.1:12302
KOR_TRAVEL_MAP_ADMIN_DAGSTER_ALLOWED_HOSTS=["127.0.0.1","localhost","::1","dagster"]
KOR_TRAVEL_MAP_ADMIN_BACKUP_ROOT=data/backups
KOR_TRAVEL_MAP_ADMIN_BACKUP_PROJECT_ROOT=.
KOR_TRAVEL_MAP_ADMIN_BACKUP_SCRIPT_PATH=scripts/docker-backup.sh
KOR_TRAVEL_MAP_ADMIN_RESTORE_SCRIPT_PATH=scripts/docker-restore.sh
KOR_TRAVEL_MAP_ADMIN_BACKUP_COMMAND_ENABLED=false
KOR_TRAVEL_MAP_ADMIN_BACKUP_COMMAND_TIMEOUT_SECONDS=1800
KOR_TRAVEL_MAP_ADMIN_RESTORE_APP_DB=kor_travel_map_restore
KOR_TRAVEL_MAP_ADMIN_RESTORE_DAGSTER_DB=kor_travel_map_dagster_restore
KOR_TRAVEL_MAP_ADMIN_RESTORE_RUSTFS_VOLUME=kor-travel-map-rustfs-restore
KOR_TRAVEL_MAP_DOCKER_ADMIN_DAGSTER_URL=http://dagster:12302
KOR_TRAVEL_MAP_DOCKER_ADMIN_DAGSTER_ALLOWED_HOSTS=["dagster","127.0.0.1","localhost","::1"]
NEXT_PUBLIC_KOR_TRAVEL_MAP_DAGSTER_URL=http://127.0.0.1:12302
DAGSTER_DISABLE_TELEMETRY=yes
KOR_TRAVEL_MAP_ADMIN_KOR_TRAVEL_GEO_BASE_URL=http://127.0.0.1:12201
# KOR_TRAVEL_MAP_ADMIN_RELOAD=false       # dev лӘЁл“ң hot-reload
# DB м—ҶлҠ” л¶ҖнҢ… кІҖмҰқм—җм„ңлҠ” features/admin/opsлҘј н•Ёк»ҳ falseлЎң лӮҙл Ө DB мқҳмЎҙ surfaceлҘј лӢ«лҠ”лӢӨ.
# admin/ops flagлҘј л№„мӣҢ л‘җл©ҙ KOR_TRAVEL_MAP_ADMIN_FEATURES_ROUTES_ENABLED к°’мқ„ л”°лҘёлӢӨ.
# KOR_TRAVEL_MAP_ADMIN_FEATURES_ROUTES_ENABLED=true
# KOR_TRAVEL_MAP_ADMIN_ADMIN_ROUTES_ENABLED=true
# KOR_TRAVEL_MAP_ADMIN_OPS_ROUTES_ENABLED=true

# ----- к°қмІҙ м ҖмһҘмҶҢ (S3 нҳёнҷҳ; RustFS мҡ°м„ , MinIO/Ceph/R2 swap к°ҖлҠҘ) -----
# RustFS лЎңм»¬ н‘ңмӨҖ: S3 API 12101, console 12105
#
# кіөмң  RustFS лӘЁл“ң (ADR-052 amendment, #372): RustFS мқён”„лқјлҠ” kor-travel-docker-managerк°Җ
# мқјкҙ„ мҶҢмң н•ңлӢӨ. кіөмң  мқёмҠӨн„ҙмҠӨлҘј м“ё л•ҢлҠ” м•„лһҳлҘј н•Ёк»ҳ м„Өм •н•ңлӢӨ.
#   KOR_TRAVEL_MAP_OBJECT_STORE_EXTERNAL=true            # docker-up.shк°Җ мһҗмІҙ rustfs лҜёкё°лҸҷ
#   KOR_TRAVEL_MAP_DOCKER_OBJECT_STORE_ENDPOINT_URL=http://host.docker.internal:12101
#   KOR_TRAVEL_MAP_EXTERNAL_DOCKER_OBJECT_STORE_ENDPOINT_URL=http://host.docker.internal:12101
#   KOR_TRAVEL_MAP_OBJECT_STORE_ACCESS_KEY_ID/SECRET_ACCESS_KEY=<kor-travel-docker-manager к°’>
KOR_TRAVEL_MAP_OBJECT_STORE_ENDPOINT_URL=http://127.0.0.1:12101
KOR_TRAVEL_MAP_OBJECT_STORE_BUCKET=kor-travel-map
KOR_TRAVEL_MAP_OBJECT_STORE_REGION=us-east-1
KOR_TRAVEL_MAP_OBJECT_STORE_ACCESS_KEY_ID=CHANGE_ME
KOR_TRAVEL_MAP_OBJECT_STORE_SECRET_ACCESS_KEY=CHANGE_ME
KOR_TRAVEL_MAP_OBJECT_STORE_PUBLIC_BASE_URL=http://127.0.0.1:12101/kor-travel-map
KOR_TRAVEL_MAP_OBJECT_STORE_PREFIX=features
KOR_TRAVEL_MAP_OFFLINE_UPLOAD_BUCKET=kor-travel-map-uploads
KOR_TRAVEL_MAP_OFFLINE_UPLOAD_PREFIX=offline-uploads
KOR_TRAVEL_MAP_OFFLINE_UPLOAD_MAX_BYTES=104857600
KOR_TRAVEL_MAP_RUSTFS_API_PORT=12101
KOR_TRAVEL_MAP_RUSTFS_CONSOLE_PORT=12105
KOR_TRAVEL_MAP_DOCKER_OBJECT_STORE_ENDPOINT_URL=http://rustfs:9000

# ----- мЈјмҶҢ/мўҢн‘ң -----
# kor-travel-geo REST API (м„ нғқ вҖ” кё°ліё лЎңм»¬ FastAPI нҸ¬нҠё 12201, Web UI 12205)
KOR_TRAVEL_MAP_KOR_TRAVEL_GEO_BASE_URL=http://127.0.0.1:12201
KOR_TRAVEL_MAP_KOR_TRAVEL_GEO_TIMEOUT_SECONDS=10.0

# ----- Dagster м Ғмһ¬ кІҖмҰқ м •мұ… (#376) -----
# strict(кё°ліё, error мқҙмҠҲ мӢң run мӢӨнҢЁ) / drop(error rowл§Ң кІ©лҰ¬ + л©”нғҖлҚ°мқҙн„° кё°лЎқ,
# мҡҙмҳҒ к¶ҢмһҘ вҖ” кІ©лҰ¬л¶„мқҖ /admin/issuesлЎң мІҳлҰ¬) / off(м „л¶Җ м Ғмһ¬)
# KOR_TRAVEL_MAP_DAGSTER_ADDRESS_VALIDATION=drop

# ----- Provider API нӮӨ -----
# `scripts/load-env.sh`мҷҖ `docker-compose.yml`мқҖ м•„лһҳ кё°мЎҙ нӮӨ мқҙлҰ„мқ„
# `KOR_TRAVEL_MAP_*`/`KOR_TRAVEL_MAP_ADMIN_*`/`NEXT_PUBLIC_*` нҷҳкІҪліҖмҲҳлЎң л§Өн•‘н•ҙ API, Dagster,
# frontend н”„лЎңм„ёмҠӨм—җ мЈјмһ…н•ңлӢӨ.
# Dagster provider record resourceк°Җ м§Ғм ‘ мқҪлҠ” main settings env.
KOR_TRAVEL_MAP_DATA_GO_KR_SERVICE_KEY=
KOR_TRAVEL_MAP_OPINET_API_KEY=
KOR_TRAVEL_MAP_KREX_EX_API_KEY=
KOR_TRAVEL_MAP_KREX_GO_API_KEY=
# KMA
KMA_API_KEY=
# VisitKorea / TourAPI
VISITKOREA_SERVICE_KEY=
# көӯк°Җмң мӮ°мІӯ
KRHERITAGE_API_KEY=
# мӮ°лҰјмІӯ
KRFOREST_API_KEY=
# кі мҶҚлҸ„лЎңкіөмӮ¬
KREX_API_KEY=
# н•ҙм–‘мЎ°мӮ¬мӣҗ
KHOA_API_KEY=
# AirKorea
AIRKOREA_API_KEY=
# OpiNet
OPINET_API_KEY=
# data.go.kr н‘ңмӨҖлҚ°мқҙн„° (мҡ°м„ мҲңмң„ мҲң)
DATAGOKR_API_KEY=
DATA_GO_KR_SERVICE_KEY=
PUBLIC_DATA_SERVICE_KEY=
SERVICE_KEY=

# ----- м „нҷ”лІҲнҳё ліҙк°• (Place phone enrichment, м„ нғқ) -----
KAKAO_LOCAL_REST_API_KEY=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=

# ----- Sentry (м„ нғқ, TripMateк°Җ мЈјмһ…н•ҳлҠ” кІҢ н‘ңмӨҖ) -----
# KOR_TRAVEL_MAP_SENTRY_DSN=

# ----- лЎңк·ё -----
KOR_TRAVEL_MAP_LOG_LEVEL=INFO
KOR_TRAVEL_MAP_LOG_FORMAT=json   # structlog JSON; stdout м§Ғм¶ңл Ҙ (Promtail мһҗлҸҷ мҲҳм§‘)
