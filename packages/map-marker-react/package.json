{
  "name": "@krtour/map-marker-react",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Common marker / category-maki dispatch / color palette for python-krtour-map debug UI and TripMate user UI. ADR-043 (2026-05-27) — npm registry 게시 보류, 모노레포 내부 workspace 공유만.",
  "license": "MIT",
  "author": "digitie",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitie/python-krtour-map.git",
    "directory": "packages/map-marker-react"
  },
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "sync:from-python": "tsx scripts/sync_from_python.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "maplibre-gl": "^5.24.0",
    "maplibre-vworld": "^0.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "maplibre-gl": "^5.24.0",
    "maplibre-vworld": "github:digitie/maplibre-vworld-js#v0.1.0",
    "zod": "^4.4.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "tsx": "^4.0.0"
  }
}
