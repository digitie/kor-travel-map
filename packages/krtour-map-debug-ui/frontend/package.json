{
  "name": "krtour-map-debug-ui-frontend",
  "version": "0.2.0-dev",
  "description": "Debug UI frontend for python-krtour-map (Next.js + maplibre-vworld, ADR-025 사용자 보강 2026-05-25).",
  "private": true,
  "scripts": {
    "dev": "next dev --port 8610 --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --port 8610 --hostname 127.0.0.1",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "gen:types": "openapi-typescript openapi.json -o src/api/types.ts",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "next": "^16.2.6",
    "maplibre-vworld": "github:digitie/maplibre-vworld-js#v0.1.2",
    "maplibre-gl": "^5.24.0",
    "zod": "^4.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "@tanstack/react-query": "^5.100.14",
    "zustand": "^5.0.14",
    "@krtour/map-marker-react": "*"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^25.9.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "openapi-typescript": "^7.13.0"
  },
  "engines": {
    "node": ">=20.9"
  }
}
