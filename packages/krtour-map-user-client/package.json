{
  "name": "@krtour/map-user-client",
  "version": "0.0.0-dev",
  "private": true,
  "description": "krtour-map user-facing OpenAPI(openapi.user.json) generated TypeScript types — TripMate 등 downstream 소비용 (T-210e). ADR-043 관행 — npm registry 게시 X, 산출물 커밋 + drift gate로 공유.",
  "license": "MIT",
  "author": "digitie",
  "repository": {
    "type": "git",
    "url": "https://github.com/digitie/python-krtour-map.git",
    "directory": "packages/krtour-map-user-client"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "gen:types": "openapi-typescript ../krtour-map-admin/openapi.user.json -o src/types.ts",
    "gen:types:check": "openapi-typescript ../krtour-map-admin/openapi.user.json -o src/types.ts --check",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}
