# =============================================================================
# python-krtour-map .env (мҳҲмӢң)
#   - мӢӨм ң .env нҢҢмқјмқҖ к¶Ңн•ң 600 лҳҗлҠ” systemd EnvironmentFile/vaultм—җ л‘”лӢӨ.
#   - нҸүл¬ё м»Өл°Ӣ кёҲм§Җ. SecretStrлЎң settingsм—җ лЎңл“ңн•ңлӢӨ.
# =============================================================================

# ----- Postgres / PostGIS -----
KRTOUR_MAP_POSTGRES_HOST_PORT=15433
KRTOUR_MAP_PG_DSN=postgresql+asyncpg://krtour_map:CHANGE_ME@127.0.0.1:15433/krtour_map
# asyncpgмҷҖ л¶„лҰ¬лҗң sync driverк°Җ н•„мҡ”н•ң лҸ„кө¬(Alembic л“ұ)лҠ” лӢӨмқҢмқ„ м¶”к°ҖлЎң м •мқҳ к°ҖлҠҘ
# KRTOUR_MAP_PG_DSN_SYNC=postgresql+psycopg://krtour_map:CHANGE_ME@127.0.0.1:15433/krtour_map
KRTOUR_MAP_DAGSTER_POSTGRES_DB=krtour_map_dagster
KRTOUR_MAP_DAGSTER_PG_URL=postgresql://krtour_map:CHANGE_ME@127.0.0.1:15433/krtour_map_dagster
KRTOUR_MAP_DOCKER_DAGSTER_PG_URL=postgresql://krtour_map:krtour_map@postgres:5432/krtour_map_dagster
KRTOUR_MAP_PG_POOL_SIZE=10
KRTOUR_MAP_PG_MAX_OVERFLOW=10
KRTOUR_MAP_PG_POOL_PRE_PING=true

# ----- л””лІ„к·ё REST API/UI (лі„лҸ„ нҢЁнӮӨм§Җ krtour-map-admin, ADR-020) -----
# л””лІ„к·ё нҢЁнӮӨм§ҖлҠ” л©”мқё лқјмқҙлёҢлҹ¬лҰ¬мҷҖ лҸҷмқј .env лҳҗлҠ” лі„лҸ„ .envм—җм„ң лЎңл“ң к°ҖлҠҘ.
# лі„лҸ„ нҢЁнӮӨм§Җм—җм„ң мқёмӢқн•ҳлҠ” prefixлҠ” KRTOUR_MAP_ADMIN_*.
KRTOUR_MAP_ADMIN_HOST=127.0.0.1       # мҷёл¶Җ л…ём¶ң кёҲм§Җ default
KRTOUR_MAP_ADMIN_PORT=9011
KRTOUR_MAP_ADMIN_WEB_PORT=9012
KRTOUR_MAP_DAGSTER_PORT=9013
KRTOUR_MAP_ADMIN_DAGSTER_URL=http://127.0.0.1:9013
KRTOUR_MAP_DOCKER_ADMIN_DAGSTER_URL=http://dagster:9013
NEXT_PUBLIC_KRTOUR_MAP_DAGSTER_URL=http://127.0.0.1:9013
DAGSTER_DISABLE_TELEMETRY=yes
KRTOUR_MAP_ADMIN_KRADDR_GEO_BASE_URL=http://127.0.0.1:9001
# KRTOUR_MAP_ADMIN_RELOAD=false       # dev лӘЁл“ң hot-reload
# DB м—ҶлҠ” л¶ҖнҢ… кІҖмҰқм—җм„ңлҠ” features/admin/opsлҘј н•Ёк»ҳ falseлЎң лӮҙл Ө DB мқҳмЎҙ surfaceлҘј лӢ«лҠ”лӢӨ.
# admin/ops flagлҘј л№„мӣҢ л‘җл©ҙ KRTOUR_MAP_ADMIN_FEATURES_ROUTES_ENABLED к°’мқ„ л”°лҘёлӢӨ.
# KRTOUR_MAP_ADMIN_FEATURES_ROUTES_ENABLED=true
# KRTOUR_MAP_ADMIN_ADMIN_ROUTES_ENABLED=true
# KRTOUR_MAP_ADMIN_OPS_ROUTES_ENABLED=true

# ----- к°қмІҙ м ҖмһҘмҶҢ (S3 нҳёнҷҳ; RustFS мҡ°м„ , MinIO/Ceph/R2 swap к°ҖлҠҘ) -----
# RustFS лЎңм»¬ н‘ңмӨҖ: S3 API 9003, console 9004
KRTOUR_MAP_OBJECT_STORE_ENDPOINT_URL=http://127.0.0.1:9003
KRTOUR_MAP_OBJECT_STORE_BUCKET=krtour-map
KRTOUR_MAP_OBJECT_STORE_REGION=us-east-1
KRTOUR_MAP_OBJECT_STORE_ACCESS_KEY_ID=CHANGE_ME
KRTOUR_MAP_OBJECT_STORE_SECRET_ACCESS_KEY=CHANGE_ME
KRTOUR_MAP_OBJECT_STORE_PUBLIC_BASE_URL=http://127.0.0.1:9003/krtour-map
KRTOUR_MAP_OBJECT_STORE_PREFIX=features
KRTOUR_MAP_OFFLINE_UPLOAD_BUCKET=krtour-uploads
KRTOUR_MAP_OFFLINE_UPLOAD_PREFIX=offline-uploads
KRTOUR_MAP_OFFLINE_UPLOAD_MAX_BYTES=104857600
KRTOUR_MAP_RUSTFS_API_PORT=9003
KRTOUR_MAP_RUSTFS_CONSOLE_PORT=9004
KRTOUR_MAP_DOCKER_OBJECT_STORE_ENDPOINT_URL=http://rustfs:9000

# ----- мЈјмҶҢ/мўҢн‘ң -----
# python-kraddr-geo REST API (м„ нғқ вҖ” кё°ліё лЎңм»¬ FastAPI нҸ¬нҠё 9001)
KRTOUR_MAP_KRADDR_GEO_BASE_URL=http://127.0.0.1:9001

# ----- Provider API нӮӨ -----
# `scripts/load-env.sh`мҷҖ `docker-compose.yml`мқҖ м•„лһҳ кё°мЎҙ нӮӨ мқҙлҰ„мқ„
# `KRTOUR_MAP_*`/`KRTOUR_MAP_ADMIN_*`/`NEXT_PUBLIC_*` нҷҳкІҪліҖмҲҳлЎң л§Өн•‘н•ҙ API, Dagster,
# frontend н”„лЎңм„ёмҠӨм—җ мЈјмһ…н•ңлӢӨ.
# Dagster provider record resourceк°Җ м§Ғм ‘ мқҪлҠ” main settings env.
KRTOUR_MAP_DATA_GO_KR_SERVICE_KEY=
KRTOUR_MAP_OPINET_API_KEY=
KRTOUR_MAP_KREX_EX_API_KEY=
KRTOUR_MAP_KREX_GO_API_KEY=
# KMA
KMA_API_KEY=
# VisitKorea / TourAPI
VISITKOREA_SERVICE_KEY=
# көӯк°Җмң мӮ°мІӯ
KRHERITAGE_API_KEY=
# мӮ°лҰјмІӯ
KRFOREST_API_KEY=
# кі мҶҚлҸ„лЎңкіөмӮ¬
KREX_API_KEY=
# н•ҙм–‘мЎ°мӮ¬мӣҗ
KHOA_API_KEY=
# AirKorea
AIRKOREA_API_KEY=
# OpiNet
OPINET_API_KEY=
# data.go.kr н‘ңмӨҖлҚ°мқҙн„° (мҡ°м„ мҲңмң„ мҲң)
DATAGOKR_API_KEY=
DATA_GO_KR_SERVICE_KEY=
PUBLIC_DATA_SERVICE_KEY=
SERVICE_KEY=

# ----- м „нҷ”лІҲнҳё ліҙк°• (Place phone enrichment, м„ нғқ) -----
KAKAO_LOCAL_REST_API_KEY=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=

# ----- Sentry (м„ нғқ, TripMateк°Җ мЈјмһ…н•ҳлҠ” кІҢ н‘ңмӨҖ) -----
# KRTOUR_MAP_SENTRY_DSN=

# ----- лЎңк·ё -----
KRTOUR_MAP_LOG_LEVEL=INFO
KRTOUR_MAP_LOG_FORMAT=json   # structlog JSON; stdout м§Ғм¶ңл Ҙ (Promtail мһҗлҸҷ мҲҳм§‘)
