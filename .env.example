# =============================================================================
# kor-travel-map .env (예시)
#   - 실제 .env 파일은 권한 600 또는 systemd EnvironmentFile/vault에 둔다.
#   - 평문 커밋 금지. SecretStr로 settings에 로드한다.
# =============================================================================

# ----- Postgres / PostGIS -----
# PC 개발 표준에서 host 5432는 kor-travel-docker-manager가 소유한
# 공유 PostgreSQL/PostGIS 서버 인스턴스다.
KOR_TRAVEL_MAP_POSTGRES_HOST_PORT=5432
KOR_TRAVEL_MAP_EXTERNAL_POSTGRES_HOST_PORT=5432
KOR_TRAVEL_MAP_POSTGRES_DB=kor_travel_map
KOR_TRAVEL_MAP_POSTGRES_USER=kor_travel_map
KOR_TRAVEL_MAP_POSTGRES_PASSWORD=CHANGE_ME
KOR_TRAVEL_MAP_PG_DSN=postgresql+asyncpg://kor_travel_map:CHANGE_ME@127.0.0.1:5432/kor_travel_map
# asyncpg와 분리된 sync driver가 필요한 도구(Alembic 등)는 다음을 추가로 정의 가능
# KOR_TRAVEL_MAP_PG_DSN_SYNC=postgresql+psycopg://kor_travel_map:CHANGE_ME@127.0.0.1:5432/kor_travel_map
KOR_TRAVEL_MAP_DAGSTER_POSTGRES_DB=kor_travel_map_dagster
KOR_TRAVEL_MAP_DAGSTER_PG_URL=postgresql://kor_travel_map:CHANGE_ME@127.0.0.1:5432/kor_travel_map_dagster
KOR_TRAVEL_MAP_DOCKER_DAGSTER_PG_URL=postgresql://kor_travel_map:kor_travel_map@postgres:5432/kor_travel_map_dagster

# ----- T-108 운영 배포 자동화: multi-platform image -----
# N150 16GB(x86_64) + Odroid M1S(ARM64) 양쪽 배포 이미지를 buildx로 만든다.
KOR_TRAVEL_MAP_IMAGE_REGISTRY=ghcr.io/digitie
KOR_TRAVEL_MAP_IMAGE_NAMESPACE=kor-travel-map
KOR_TRAVEL_MAP_IMAGE_TAG=dev
KOR_TRAVEL_MAP_DOCKER_PLATFORMS=linux/amd64,linux/arm64
# registry(기본, --push) / docker(단일 platform --load) / oci(OCI archive)
KOR_TRAVEL_MAP_BUILDX_OUTPUT=registry

# kor-travel-docker-manager 공유 PostGIS(:5432)를 쓰고 RustFS는 local compose로 띄울 때:
#   KOR_TRAVEL_MAP_DB_EXTERNAL=true
#   KOR_TRAVEL_MAP_EXTERNAL_POSTGRES_HOST_PORT=5432
#   KOR_TRAVEL_MAP_EXTERNAL_DOCKER_PG_DSN=postgresql+asyncpg://kor_travel_map:CHANGE_ME@host.docker.internal:5432/kor_travel_map
#   KOR_TRAVEL_MAP_EXTERNAL_DOCKER_DAGSTER_PG_URL=postgresql://kor_travel_map:CHANGE_ME@host.docker.internal:5432/kor_travel_map_dagster
# 공유 PostGIS(:5432)와 공유 RustFS(:12101)를 모두 쓸 때는 local postgres/rustfs를 띄우지 않는다.
#   KOR_TRAVEL_MAP_INFRA_EXTERNAL=true
#   KOR_TRAVEL_MAP_EXTERNAL_POSTGRES_HOST_PORT=5432
#   KOR_TRAVEL_MAP_EXTERNAL_DOCKER_PG_DSN=postgresql+asyncpg://kor_travel_map:CHANGE_ME@host.docker.internal:5432/kor_travel_map
#   KOR_TRAVEL_MAP_EXTERNAL_DOCKER_DAGSTER_PG_URL=postgresql://kor_travel_map:CHANGE_ME@host.docker.internal:5432/kor_travel_map_dagster
KOR_TRAVEL_MAP_PG_POOL_SIZE=10
KOR_TRAVEL_MAP_PG_MAX_OVERFLOW=10
KOR_TRAVEL_MAP_PG_POOL_PRE_PING=true

# ----- REST API / admin UI (ADR-055 split) -----
# Python API 패키지(`kor-travel-map-api`)는 KOR_TRAVEL_MAP_API_* prefix를 사용하고,
# admin frontend(`kor-travel-map-admin/frontend`)는 NEXT_PUBLIC_* 값을 사용한다.
# Docker compose host publish 기본값은 localhost다. 외부 노출은 네트워크 보호를
# 먼저 둔 뒤 명시 opt-in한다.
#
# [shell-quoting] JSON 리스트 값(ALLOWED_HOSTS / CORS_ALLOW_ORIGINS 등)은 .env가
# `scripts/load-env.sh`에서 `set -a; source .env`로 bash에 source되므로 반드시
# 작은따옴표로 감싼다. 큰따옴표가 안 감싸이면 bash가 inner `"`를 벗겨내
# `["x"]` -> `[x]`가 되어 Pydantic list[str] 파싱이 깨진다 (#506).
# KOR_TRAVEL_MAP_DOCKER_BIND_HOST=0.0.0.0
KOR_TRAVEL_MAP_API_HOST=127.0.0.1       # 외부 노출 금지 default
KOR_TRAVEL_MAP_API_PORT=12701
KOR_TRAVEL_MAP_ADMIN_WEB_PORT=12705
KOR_TRAVEL_MAP_DAGSTER_PORT=12702
KOR_TRAVEL_MAP_API_DAGSTER_URL=http://127.0.0.1:12702
KOR_TRAVEL_MAP_API_DAGSTER_ALLOWED_HOSTS='["127.0.0.1","localhost","::1","dagster"]'
KOR_TRAVEL_MAP_API_BACKUP_ROOT=data/backups
KOR_TRAVEL_MAP_API_BACKUP_PROJECT_ROOT=.
KOR_TRAVEL_MAP_API_BACKUP_SCRIPT_PATH=scripts/docker-backup.sh
KOR_TRAVEL_MAP_API_RESTORE_SCRIPT_PATH=scripts/docker-restore.sh
KOR_TRAVEL_MAP_API_BACKUP_COMMAND_ENABLED=false
KOR_TRAVEL_MAP_API_BACKUP_COMMAND_TIMEOUT_SECONDS=1800
KOR_TRAVEL_MAP_API_RESTORE_APP_DB=kor_travel_map_restore
KOR_TRAVEL_MAP_API_RESTORE_DAGSTER_DB=kor_travel_map_dagster_restore
KOR_TRAVEL_MAP_API_RESTORE_RUSTFS_VOLUME=kor-travel-map-rustfs-restore
KOR_TRAVEL_MAP_API_ADMIN_PROXY_SECRET=CHANGE_ME_SERVER_ONLY
KOR_TRAVEL_MAP_API_ADMIN_TRUSTED_PROXY_CIDRS='["127.0.0.1/32","::1/128"]'
KOR_TRAVEL_MAP_API_PUBLIC_API_KEY_REQUIRED=true
KOR_TRAVEL_MAP_API_PUBLIC_API_KEY_CACHE_TTL_S=30
KOR_TRAVEL_MAP_API_VWORLD_API_KEY=CHANGE_ME
KOR_TRAVEL_MAP_DOCKER_API_DAGSTER_URL=http://dagster:12702
KOR_TRAVEL_MAP_DOCKER_API_DAGSTER_ALLOWED_HOSTS='["dagster","127.0.0.1","localhost","::1"]'
KOR_TRAVEL_MAP_API_INTERNAL_URL=http://127.0.0.1:12701
KOR_TRAVEL_MAP_ADMIN_PROXY_SECRET=CHANGE_ME_SERVER_ONLY
KOR_TRAVEL_MAP_UI_ADMIN_USERNAME=admin
KOR_TRAVEL_MAP_UI_ADMIN_PASSWORD_HASH=CHANGE_ME_PBKDF2_HASH
KOR_TRAVEL_MAP_UI_SESSION_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
KOR_TRAVEL_MAP_UI_TRUST_PROXY_HEADERS=false
# 신뢰할 공개 브라우저 origin(쉼표 구분). TLS 종단 프록시(HAProxy 등)가 X-Forwarded-Proto를
# 주입하지 않으면 same-origin(CSRF) 검사가 http로 재구성돼 https 공개 도메인 로그인이 403
# (INVALID_ORIGIN)이 되므로, 공개 도메인을 명시해 허용한다(브라우저 Origin을 화이트리스트와
# 대조 — CSRF 유지). 예) KOR_TRAVEL_MAP_UI_PUBLIC_ORIGINS=https://map.example.org
KOR_TRAVEL_MAP_UI_PUBLIC_ORIGINS=
NEXT_PUBLIC_KOR_TRAVEL_MAP_API=http://127.0.0.1:12701
NEXT_PUBLIC_KOR_TRAVEL_MAP_DAGSTER_URL=http://127.0.0.1:12702
DAGSTER_DISABLE_TELEMETRY=yes

# ----- 프로덕션 reverse-proxy 도메인 (예시 — 실 도메인은 gitignored .env에만) -----
# reverse proxy(Caddy/nginx/Cloudflare Tunnel)가 TLS 종단 + 아래 라우팅을 담당한다.
# 실제 도메인은 git에 올리지 않고 운영 노드의 .env(또는 .env.prod)에만 둔다.
#   <map-host>         -> frontend (admin UI, :12705)
#   <map-api-host>     -> api      (FastAPI,   :12701)
#   <map-dagster-host> -> dagster  (Dagster UI, :12702)
#   <s3-api-host>      -> rustfs    S3 API     (:12101)
#   <s3-console-host>  -> rustfs    console    (:12105)
#   <geo-api-host>     -> kor-travel-geo REST API (:12501)
#   <geo-console-host> -> kor-travel-geo Web UI   (:12505)
# 프론트(브라우저) → API/Dagster (Next.js build-time inline — 도메인 변경 시 재빌드):
# NEXT_PUBLIC_KOR_TRAVEL_MAP_API=https://map-api.example.org
# NEXT_PUBLIC_KOR_TRAVEL_MAP_DAGSTER_URL=https://map-dagster.example.org
# API CORS: 프론트 origin을 허용해야 브라우저 fetch가 통과한다(JSON 배열).
# docker-compose.yml은 이 env가 있으면 그대로 쓰고, 없으면 localhost로 fallback한다.
# KOR_TRAVEL_MAP_API_CORS_ALLOW_ORIGINS='["https://map.example.org"]'
# 객체 저장소 브라우저-facing object URL(S3 API 도메인 + 버킷). API→RustFS 내부 통신은
# docker 네트워크(http://rustfs:9000)를 그대로 쓰고, 외부 노출은 이 public URL뿐이다.
# KOR_TRAVEL_MAP_OBJECT_STORE_PUBLIC_BASE_URL=https://s3-api.example.org/kor-travel-map
# kor-travel-geo(주소/좌표). 프론트(브라우저)는 NEXT_PUBLIC, 백엔드(API/Dagster)는 main
# settings env. 백엔드 값을 비우면 정/역지오코딩 보강이 꺼진다(좌표만 적재). geo가 같은
# docker 호스트면 백엔드는 http://host.docker.internal:12501 이 더 효율적이다.
# NEXT_PUBLIC_KOR_TRAVEL_GEO_BASE_URL=https://geo-api.example.org
# KOR_TRAVEL_MAP_KOR_TRAVEL_GEO_BASE_URL=https://geo-api.example.org
# geo PR#399 이후 v2 public API는 VWorld 호환 `key` query가 필요하다.
# 현재는 VWorld API key와 동일 값을 넣는다.
# NEXT_PUBLIC_KOR_TRAVEL_GEO_API_KEY=$NEXT_PUBLIC_VWORLD_API_KEY
# KOR_TRAVEL_MAP_KOR_TRAVEL_GEO_API_KEY=$NEXT_PUBLIC_VWORLD_API_KEY
# KOR_TRAVEL_MAP_API_RELOAD=false       # dev 모드 hot-reload
# DB 없는 부팅 검증에서는 features/admin/ops를 함께 false로 내려 DB 의존 surface를 닫는다.
# admin/ops flag를 비워 두면 KOR_TRAVEL_MAP_API_FEATURES_ROUTES_ENABLED 값을 따른다.
# KOR_TRAVEL_MAP_API_FEATURES_ROUTES_ENABLED=true
# KOR_TRAVEL_MAP_API_ADMIN_ROUTES_ENABLED=true
# KOR_TRAVEL_MAP_API_OPS_ROUTES_ENABLED=true

# ----- Prometheus / 관측 -----
# kor-travel-docker-manager 관측 스택은 Grafana 12205, cAdvisor Exporter 12301,
# Prometheus 12401을 사용한다. kor-travel-map API는 Prometheus에 능동 연결하지 않고,
# API 포트(기본 12701)의 /metrics를 Prometheus가 pull scrape한다. 이 endpoint는
# REST HTTP와 DB query 성능 메트릭을 함께 제공한다.
KOR_TRAVEL_MAP_API_PROMETHEUS_METRICS_ENABLED=true
KOR_TRAVEL_MAP_API_PROMETHEUS_METRICS_PATH=/metrics

# ----- 객체 저장소 (S3 호환; RustFS 우선, MinIO/Ceph/R2 swap 가능) -----
# RustFS 로컬 표준: S3 API 12101, console 12105
#
# 공유 RustFS 모드 (ADR-052 amendment, #372): RustFS 인프라는 kor-travel-docker-manager가
# 일괄 소유한다. 공유 인스턴스를 쓸 때는 아래를 함께 설정한다.
#   KOR_TRAVEL_MAP_OBJECT_STORE_EXTERNAL=true            # docker-up.sh가 자체 rustfs 미기동
#   KOR_TRAVEL_MAP_DOCKER_OBJECT_STORE_ENDPOINT_URL=http://host.docker.internal:12101
#   KOR_TRAVEL_MAP_EXTERNAL_DOCKER_OBJECT_STORE_ENDPOINT_URL=http://host.docker.internal:12101
#   KOR_TRAVEL_MAP_OBJECT_STORE_ACCESS_KEY_ID/SECRET_ACCESS_KEY=<kor-travel-docker-manager 값>
KOR_TRAVEL_MAP_OBJECT_STORE_ENDPOINT_URL=http://127.0.0.1:12101
KOR_TRAVEL_MAP_OBJECT_STORE_BUCKET=kor-travel-map
KOR_TRAVEL_MAP_OBJECT_STORE_REGION=us-east-1
KOR_TRAVEL_MAP_OBJECT_STORE_ACCESS_KEY_ID=CHANGE_ME
KOR_TRAVEL_MAP_OBJECT_STORE_SECRET_ACCESS_KEY=CHANGE_ME
KOR_TRAVEL_MAP_OBJECT_STORE_PUBLIC_BASE_URL=http://127.0.0.1:12101/kor-travel-map
KOR_TRAVEL_MAP_OBJECT_STORE_PREFIX=features
KOR_TRAVEL_MAP_OFFLINE_UPLOAD_BUCKET=kor-travel-map-uploads
KOR_TRAVEL_MAP_OFFLINE_UPLOAD_PREFIX=offline-uploads
KOR_TRAVEL_MAP_OFFLINE_UPLOAD_MAX_BYTES=104857600
KOR_TRAVEL_MAP_RUSTFS_API_PORT=12101
KOR_TRAVEL_MAP_RUSTFS_CONSOLE_PORT=12105
KOR_TRAVEL_MAP_DOCKER_OBJECT_STORE_ENDPOINT_URL=http://rustfs:9000

# ----- 주소/좌표 -----
# kor-travel-geo REST API (선택 — docker-manager 표준 API 12501, Web UI 12505)
KOR_TRAVEL_MAP_KOR_TRAVEL_GEO_BASE_URL=http://127.0.0.1:12501
KOR_TRAVEL_MAP_KOR_TRAVEL_GEO_TIMEOUT_SECONDS=10.0
KOR_TRAVEL_MAP_KOR_TRAVEL_GEO_API_KEY=CHANGE_ME  # 현재는 VWorld API key와 동일

# ----- Dagster 적재 검증 정책 (#376) -----
# strict(기본, error 이슈 시 run 실패) / drop(error row만 격리 + 메타데이터 기록,
# 운영 권장 — 격리분은 /admin/issues로 처리) / off(전부 적재)
# KOR_TRAVEL_MAP_DAGSTER_ADDRESS_VALIDATION=drop

# ----- Provider API 키 -----
# `scripts/load-env.sh`와 `docker-compose.yml`은 아래 기존 키 이름을
# `KOR_TRAVEL_MAP_*`/`KOR_TRAVEL_MAP_API_*`/`NEXT_PUBLIC_*` 환경변수로 매핑해 API, Dagster,
# frontend 프로세스에 주입한다.
# Dagster provider record resource가 직접 읽는 main settings env.
KOR_TRAVEL_MAP_DATA_GO_KR_SERVICE_KEY=
KOR_TRAVEL_MAP_MOIS_SOURCE_DB_PATH=/app/data/mois/mois.db
KOR_TRAVEL_MAP_MOIS_SOURCE_DB_VOLUME=kor-travel-map-mois-source
KOR_TRAVEL_MAP_OPINET_API_KEY=
KOR_TRAVEL_MAP_KREX_EX_API_KEY=
KOR_TRAVEL_MAP_KREX_GO_API_KEY=
# KMA
KMA_API_KEY=
# VisitKorea / TourAPI
VISITKOREA_SERVICE_KEY=
# 국가유산청
KRHERITAGE_API_KEY=
# 산림청
KRFOREST_API_KEY=
# 고속도로공사
KREX_API_KEY=
# 해양조사원
KHOA_API_KEY=
# AirKorea
AIRKOREA_API_KEY=
# OpiNet
OPINET_API_KEY=
# disabled | bbox | poi_cache_target | low_top_area
KOR_TRAVEL_MAP_OPINET_SCOPE_MODE=low_top_area
# bbox 모드에서만 사용: min_lon,min_lat,max_lon,max_lat
KOR_TRAVEL_MAP_OPINET_SCOPE_BBOX=
KOR_TRAVEL_MAP_OPINET_SCOPE_RADIUS_M=5000
# data.go.kr 표준데이터 (우선순위 순)
DATAGOKR_API_KEY=
DATA_GO_KR_SERVICE_KEY=
PUBLIC_DATA_SERVICE_KEY=
SERVICE_KEY=

# ----- Admin 주소/POI 검색 + 전화번호 보강 (선택) -----
# Admin curated feature place search는 KOR_TRAVEL_MAP_* 값을 직접 읽는다.
# 아래 짧은 이름은 provider library/기존 .env 호환이며 scripts/load-env.sh와
# docker-compose.yml이 KOR_TRAVEL_MAP_*로 매핑한다.
KOR_TRAVEL_MAP_KAKAO_LOCAL_REST_API_KEY=
KOR_TRAVEL_MAP_NAVER_SEARCH_CLIENT_ID=
KOR_TRAVEL_MAP_NAVER_SEARCH_CLIENT_SECRET=
KOR_TRAVEL_MAP_GOOGLE_PLACES_API_KEY=
KAKAO_LOCAL_REST_API_KEY=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=

# ----- Sentry (선택, TripMate가 주입하는 게 표준) -----
# KOR_TRAVEL_MAP_SENTRY_DSN=

# ----- 로그 -----
KOR_TRAVEL_MAP_LOG_LEVEL=INFO
KOR_TRAVEL_MAP_LOG_FORMAT=json   # structlog JSON; stdout 직출력 (Promtail 자동 수집)
