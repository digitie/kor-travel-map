    "/features": {
      "get": {
        "description": "주어진 경계 상자(WGS84) 안의 feature 경량 표현 list. ``coord``의 GIST 인덱스를 사용하는 공간 조회 (ADR-012). ``kind`` 반복 파라미터로 종류 필터 (예: ``?kind=place&kind=event``). 삭제된 feature 제외.",
        "operationId": "list_features_in_bbox_features_get",
        "parameters": [
          {
            "description": "bbox 최소 경도 (WGS84).",
            "in": "query",
            "name": "min_lon",
            "required": true,
            "schema": {
              "description": "bbox 최소 경도 (WGS84).",
              "title": "Min Lon",
              "type": "number"
            }
          },
          {
            "description": "bbox 최소 위도.",
            "in": "query",
            "name": "min_lat",
            "required": true,
            "schema": {
              "description": "bbox 최소 위도.",
              "title": "Min Lat",
              "type": "number"
            }
          },
          {
            "description": "bbox 최대 경도.",
            "in": "query",
            "name": "max_lon",
            "required": true,
            "schema": {
              "description": "bbox 최대 경도.",
              "title": "Max Lon",
              "type": "number"
            }
          },
          {
            "description": "bbox 최대 위도.",
            "in": "query",
            "name": "max_lat",
            "required": true,
            "schema": {
              "description": "bbox 최대 위도.",
              "title": "Max Lat",
              "type": "number"
            }
          },
          {
            "description": "feature kind 필터 (반복 가능). 미지정 시 전체.",
            "in": "query",
            "name": "kind",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "description": "feature kind 필터 (반복 가능). 미지정 시 전체.",
              "title": "Kind"
            }
          },
          {
            "description": "최대 반환 수.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 1000,
              "description": "최대 반환 수.",
              "maximum": 5000,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeaturesInBboxResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "bbox 안 feature 목록 (지도 뷰포트)",
        "tags": [
          "features"
        ]
      }
    },
