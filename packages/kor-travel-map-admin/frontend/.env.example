# =============================================================================
# kor-travel-map-admin frontend .env (ADR-025, Next.js 기반)
#   - .env.local로 복사해서 사용. .env.local은 .gitignore (절대 commit X).
#   - VWorld API key는 HTTP referrer 제한 설정 권장 (운영자).
#   - Next.js env 규약: NEXT_PUBLIC_* 만 브라우저 노출, 그 외는 server-only.
# =============================================================================

# ----- VWorld 지도 (MapLibre GL, ADR-025 + ADR-026) -----
# kor-travel-geo ADR-019의 KOR_TRAVEL_GEO_VWORLD_API_KEY를 **공유 사용**.
# 별도 발급 금지 (ADR-025 사용자 보강 2026-05-25).
# 운영 시 backend가 .env(KOR_TRAVEL_GEO_VWORLD_API_KEY)에서 읽어 frontend 빌드 시
# 동일 값을 NEXT_PUBLIC_VWORLD_API_KEY로 주입 (CI/CD 또는 운영 셸 스크립트 책임).
# HTTP referrer 제한 권장 (backend 호스트 + PinVi frontend 호스트).
NEXT_PUBLIC_VWORLD_API_KEY=CHANGE_ME  # = $KOR_TRAVEL_GEO_VWORLD_API_KEY 값과 동일해야 함

# ----- Backend API base URL -----
# 개발: Next.js dev/start (12705) → FastAPI (12701, docker-manager map 포트).
# 운영: Next.js standalone 또는 next/api proxy로 FastAPI와 같은 호스트에 배치.
# 운영 build/start에서는 아래 NEXT_PUBLIC_* 값을 명시해야 하며 localhost fallback 없음.
NEXT_PUBLIC_KOR_TRAVEL_MAP_API=http://127.0.0.1:12701
NEXT_PUBLIC_KOR_TRAVEL_MAP_DAGSTER_URL=http://127.0.0.1:12702
NEXT_PUBLIC_KOR_TRAVEL_GEO_BASE_URL=http://127.0.0.1:12501
NEXT_PUBLIC_KOR_TRAVEL_GEO_API_KEY=CHANGE_ME  # 현재는 NEXT_PUBLIC_VWORLD_API_KEY와 동일

# ----- Admin login / BFF proxy (server-only, 브라우저 노출 금지) -----
KOR_TRAVEL_MAP_API_INTERNAL_URL=http://127.0.0.1:12701
KOR_TRAVEL_MAP_ADMIN_PROXY_SECRET=CHANGE_ME_SERVER_ONLY
KOR_TRAVEL_MAP_UI_ADMIN_USERNAME=admin
KOR_TRAVEL_MAP_UI_ADMIN_PASSWORD_HASH=CHANGE_ME_PBKDF2_HASH
KOR_TRAVEL_MAP_UI_SESSION_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
# reverse proxy가 X-Forwarded-For/X-Real-IP를 덮어쓰는 배포에서만 true.
KOR_TRAVEL_MAP_UI_TRUST_PROXY_HEADERS=false

# ----- 옵션 -----
# NEXT_PUBLIC_MAP_DEFAULT_LON=127.0
# NEXT_PUBLIC_MAP_DEFAULT_LAT=37.5
# NEXT_PUBLIC_MAP_DEFAULT_ZOOM=10

# ops-live WebSocket kill-switch (#503). "1"이면 useOpsLiveInvalidation이 항상
# enabled=false로 동작해 /v1/ops/live WS를 절대 열지 않는다. **기본 ENABLED**(미설정/"0"
# 모두 라이브 켜짐)라 prod 실시간 invalidation은 영향 없음. mocked e2e 빌드처럼 라이브
# 백엔드 없이 화면을 띄울 때만 켠다(1차 방어선은 e2e/ws-isolation.ts WS 스텁).
# NEXT_PUBLIC_DISABLE_OPS_LIVE=1
