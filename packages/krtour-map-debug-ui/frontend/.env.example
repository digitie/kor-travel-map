# =============================================================================
# krtour-map-debug-ui frontend .env (ADR-025)
#   - .env.local로 복사해서 사용. .env.local은 .gitignore (절대 commit X).
#   - VWorld API key는 HTTP referrer 제한 설정 권장 (운영자).
# =============================================================================

# ----- VWorld 지도 (maplibre-vworld, ADR-025) -----
# python-kraddr-geo의 KRADDR_GEO_VWORLD_API_KEY를 공유하거나 디버그 UI 전용 키 발급
VITE_VWORLD_API_KEY=CHANGE_ME

# ----- Backend API base URL -----
# 개발: Vite dev (8610) → FastAPI (8600). 운영: FastAPI static mount이라 same-origin
VITE_KRTOUR_MAP_DEBUG_UI_API=http://127.0.0.1:8600

# ----- 옵션 -----
# VITE_MAP_DEFAULT_LON=127.0
# VITE_MAP_DEFAULT_LAT=37.5
# VITE_MAP_DEFAULT_ZOOM=10
