    "/debug/etl/{provider}/{dataset}/preview": {
      "post": {
        "description": "fixture 또는 live source로 provider raw → DTO 변환을 실행하고 결과를 JSON으로 응답. DB write 없음. fixture 모드는 외부 의존 X. live 모드는 `etl_live.LIVE_LOADER_REGISTRY` 등록된 dataset만 — `?source=fixture` 응답의 `live_supported` 필드로 확인.",
        "operationId": "post_preview_debug_etl__provider___dataset__preview_post",
        "parameters": [
          {
            "in": "path",
            "name": "provider",
            "required": true,
            "schema": {
              "title": "Provider",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "dataset",
            "required": true,
            "schema": {
              "title": "Dataset",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "source",
            "required": false,
            "schema": {
              "default": "fixture",
              "enum": [
                "fixture",
                "live"
              ],
              "title": "Source",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EtlPreviewResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "description": "등록되지 않은 (provider, dataset) 조합"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "501": {
            "description": "source=live 미구현 (LIVE_LOADER_REGISTRY 미등록)"
          },
          "502": {
            "description": "provider 외부 API 호출 실패"
          },
          "503": {
            "description": "API key 미설정 (.env 확인)"
          }
        },
        "summary": "provider 변환 함수 dry-run preview",
        "tags": [
          "debug",
          "etl"
        ]
      }
